{
	"info": {
		"_postman_id": "secretario-app-api",
		"name": "SecretarioApp - WhatsApp API",
		"description": "Collection para testar as APIs de criação de instância WhatsApp e configuração de webhook",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Evolution API - Direta",
			"item": [
				{
					"name": "1. Criar Instância",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							},
							{
								"key": "apikey",
								"value": "{{api_key}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"instanceName\": \"{{instance_name}}\",\n  \"qrcode\": true,\n  \"integration\": \"WHATSAPP-BAILEYS\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url_evolution}}/instance/create",
							"host": [
								"{{base_url_evolution}}"
							],
							"path": [
								"instance",
								"create"
							]
						},
						"description": "Cria uma nova instância WhatsApp na Evolution API"
					},
					"response": []
				},
				{
					"name": "2. Obter QR Code",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "apikey",
								"value": "{{api_key}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url_evolution}}/instance/connect/{{instance_name}}?qrcode=true",
							"host": [
								"{{base_url_evolution}}"
							],
							"path": [
								"instance",
								"connect",
								"{{instance_name}}"
							],
							"query": [
								{
									"key": "qrcode",
									"value": "true"
								}
							]
						},
						"description": "Obtém o QR code ou pairing code da instância"
					},
					"response": []
				},
				{
					"name": "3. Verificar Status",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "apikey",
								"value": "{{api_key}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url_evolution}}/instance/connectionState/{{instance_name}}",
							"host": [
								"{{base_url_evolution}}"
							],
							"path": [
								"instance",
								"connectionState",
								"{{instance_name}}"
							]
						},
						"description": "Verifica o status de conexão da instância"
					},
					"response": []
				},
				{
					"name": "4. Configurar Webhook",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							},
							{
								"key": "apikey",
								"value": "{{api_key}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"url\": \"{{webhook_url}}/\",\n  \"events\": [\n    \"APPLICATION_STARTUP\",\n    \"QRCODE_UPDATED\",\n    \"MESSAGES_UPSERT\",\n    \"MESSAGES_UPDATE\",\n    \"CONNECTION_UPDATE\"\n  ],\n  \"webhook_by_events\": false,\n  \"webhook_base64\": false,\n  \"headers\": {\n    \"Content-Type\": \"application/json\"\n  }\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url_evolution}}/webhook/set/{{instance_name}}",
							"host": [
								"{{base_url_evolution}}"
							],
							"path": [
								"webhook",
								"set",
								"{{instance_name}}"
							]
						},
						"description": "Configura o webhook para a instância. IMPORTANTE: URL deve terminar com /"
					},
					"response": []
				}
			],
			"description": "APIs diretas da Evolution API (sem passar pelo Laravel)"
		},
		{
			"name": "Laravel API - Interna",
			"item": [
				{
					"name": "1. Criar Instância",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							},
							{
								"key": "Accept",
								"value": "application/json",
								"type": "text"
							},
							{
								"key": "X-CSRF-TOKEN",
								"value": "{{csrf_token}}",
								"type": "text",
								"description": "Obter do cookie ou sessão"
							},
							{
								"key": "X-Requested-With",
								"value": "XMLHttpRequest",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"whatsapp_number\": \"{{instance_name}}\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url_laravel}}/settings/whatsapp/connect",
							"host": [
								"{{base_url_laravel}}"
							],
							"path": [
								"settings",
								"whatsapp",
								"connect"
							]
						},
						"description": "Cria instância via API Laravel (requer autenticação)"
					},
					"response": []
				},
				{
					"name": "2. Obter QR Code",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url_laravel}}/settings/whatsapp/qrcode",
							"host": [
								"{{base_url_laravel}}"
							],
							"path": [
								"settings",
								"whatsapp",
								"qrcode"
							]
						},
						"description": "Obtém QR code via API Laravel"
					},
					"response": []
				},
				{
					"name": "3. Verificar Status",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url_laravel}}/settings/whatsapp/status",
							"host": [
								"{{base_url_laravel}}"
							],
							"path": [
								"settings",
								"whatsapp",
								"status"
							]
						},
						"description": "Verifica status via API Laravel"
					},
					"response": []
				},
				{
					"name": "4. Configurar Webhook",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							},
							{
								"key": "Accept",
								"value": "application/json",
								"type": "text"
							},
							{
								"key": "X-CSRF-TOKEN",
								"value": "{{csrf_token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"url\": \"{{webhook_url}}/\",\n  \"events\": [\n    \"APPLICATION_STARTUP\",\n    \"QRCODE_UPDATED\",\n    \"MESSAGES_UPSERT\",\n    \"MESSAGES_UPDATE\",\n    \"CONNECTION_UPDATE\"\n  ],\n  \"webhook_base64\": false\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url_laravel}}/settings/whatsapp/webhook",
							"host": [
								"{{base_url_laravel}}"
							],
							"path": [
								"settings",
								"whatsapp",
								"webhook"
							]
						},
						"description": "Configura webhook via API Laravel"
					},
					"response": []
				}
			],
			"description": "APIs internas do Laravel (requerem autenticação e CSRF token)"
		},
